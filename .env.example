# ─── Database ───────────────────────────────────────────────────────────────
MONGODB_URI=

# ─── JWT (RS256) ─────────────────────────────────────────────────────────────
# Paste the full PEM string with newlines escaped as \n
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ─── Admin ───────────────────────────────────────────────────────────────────
# Remove — not used. Sessions are JWT-based.


# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000


# ─── Encryption (AES-256) ────────────────────────────────────────────────────
# 32-byte hex key for field-level encryption
AES_ENCRYPTION_KEY=

# ─── OAuth Providers (configured per wizard) ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── Email (optional) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Redis (optional, for prod rate limiting) ────────────────────────────────
REDIS_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
